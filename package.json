{
  "name": "startup-launch-suite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "start": "node server.js",
    "preview": "vite preview --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:checks": "vitest run src/export-checks.test.ts",
    "security:scan": "node security-scan.js",
    "security:fix": "node security-scan.js --fix"
  },
  "dependencies": {
    "@tippyjs/react": "^4.2.6",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.545.0",
    "pg": "^8.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-joyride": "^3.1.0",
    "stripe": "^22.1.1",
    "tippy.js": "^6.3.7",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "typescript": "~5.9.2",
    "vitest": "^4.1.7"
  }
}
